{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.xllinbupt/liepin-cli",
  "title": "Liepin CLI",
  "description": "Liepin job search and resume workflows via liepin-cli local CLI tool.",
  "version": "1.1.0",
  "repository": {
    "url": "https://github.com/xllinbupt/MCP2skill",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://open-agent.liepin.com/mcp/user",
      "headers": [
        {
          "name": "x-user-token",
          "description": "Liepin user token from the Liepin MCP configuration page.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "source_url": "https://github.com/xllinbupt/MCP2skill",
      "skill_path": "liepin-cli/SKILL.md",
      "auth_required": true
    }
  }
}
